DOMAIN_NAME=domain.com
CONTAINERS_SUBNET=172.42.0.0
TIMEZONE=America/Sao_Paulo

# Host user the Authelia container runs as, so it doesn't run as root and
# take ownership of the ./authelia/config bind mount. Match your host user:
# run `id -u` / `id -g`.
PUID=1000
PGID=1000

# Traefik
CT_TRAEFIK=traefik
CT_TRAEFIK_IP=172.42.0.2
TRAEFIK_VERSION=v3.6

# Pi-Hole
CT_PIHOLE=pihole
CT_PIHOLE_VERSION=2024.07.0
CT_PIHOLE_IP=172.42.0.3
# Real LAN IP of the host machine, used for dns.hosts (docker.local -> this IP)
PIHOLE_HOST_IP=192.168.0.10
# Start address of the DHCP pool (dhcp.start)
PIHOLE_DHCP_START=192.168.0.100
# DNS interface listening mode ("bind only interface" in the web UI). See
# https://docs.pi-hole.net/ftldns/interfaces/ for allowed values (LOCAL, SINGLE, BIND, ALL, NONE).
PIHOLE_LISTENING_MODE=BIND
# Senha de admin da UI/API. Aplicada via FTLCONF_webserver_api_password no
# primeiro start do container (ou sempre que ./config/etc-pihole for apagado).
PIHOLE_PASSWORD=changeme

# Unbound
CT_UNBOUND_IP=172.42.0.4
CT_UNBOUND_PORT=5053

# Portainer
CT_PORTAINER=portainer
CT_PORTAINER_IP=172.42.0.5
PORTAINER_PORT_HTTP=9000

# Authelia
CT_AUTHELIA=authelia
CT_AUTHELIA_IP=172.42.0.6
AUTHELIA_VERSION=4.39

# Authelia Postgres (storage backend). Container name must match the host
# used in authelia/config/configuration.yml (storage.postgres.address).
CT_AUTHELIA_POSTGRES=authelia-postgres
CT_AUTHELIA_POSTGRES_IP=172.42.0.7
POSTGRES_VERSION=16

# Authelia Redis (session store). Container name must match the host
# used in authelia/config/configuration.yml (session.redis.host).
CT_AUTHELIA_REDIS=authelia-redis
CT_AUTHELIA_REDIS_IP=172.42.0.8
REDIS_VERSION=7

# IP usados nos templates do traefik
COOLIFY_IP=192.168.0.3
GITLAB_IP=192.168.0.2
GITLAB_PAGES_IP=$GITLAB_IP:9090
GITLAB_REGISTRY_IP=$GITLAB_IP:5050
GITLAB_SSH_PORT=2222
MAILPIT_IP=192.168.0.4:8025
PVE_IP=192.168.0.5:8006